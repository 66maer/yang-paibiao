# ============================================
# Docker 镜像配置
# ============================================
# 生产环境统一使用 ghcr.io 作为 canonical 镜像名
DOCKER_REGISTRY=ghcr.io
# 多个 GHCR 代理按顺序回退尝试，最后会回退到 ghcr.io
DOCKER_REGISTRY_CANDIDATES=ghcr.m.daocloud.io,m.daocloud.io/ghcr.io,dockerproxy.net/ghcr.io,dockerproxy.com/ghcr.io,docker.1ms.run/ghcr.io,docker.nju.edu.cn/ghcr.io,docker.mirrors.sjtug.sjtu.edu.cn/ghcr.io,dockerhub.azk8s.cn/ghcr.io,ghcr.io
DOCKER_USERNAME=66maer
VERSION=latest

# ============================================
# 数据库配置
# ============================================
# 🔒 安全提示：请使用强密码！
# 生成方法：openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ============================================
# 后端配置
# ============================================
# 🔒 安全提示：JWT 密钥必须足够长且随机！
# 生成方法：openssl rand -base64 48
SECRET_KEY=CHANGE_ME_TO_STRONG_SECRET_KEY_AT_LEAST_32_CHARACTERS

# ============================================
# API 配置
# ============================================
API_BASE_URL=/api/v2

# ============================================
# Bot 配置
# ============================================
# Bot 监听地址和端口（容器内）
BOT_HOST=0.0.0.0
BOT_PORT=8080

# Bot 对外端口（宿主机）
BOT_EXTERNAL_PORT=8080

# ============================================
# 其他配置
# ============================================
ENVIRONMENT=production
