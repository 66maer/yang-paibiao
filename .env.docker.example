# ============================================
# Docker 镜像配置
# ============================================
# Compose 固定使用正式镜像名，部署脚本会从下方候选镜像源中自动回退拉取
DOCKER_CANONICAL_REGISTRY=ghcr.io
# 兼容旧配置：优先尝试的镜像源
DOCKER_REGISTRY=ghcr.nju.edu.cn
# 多个候选镜像源，空格分隔；支持直接替换和单域名前缀两种写法
DOCKER_REGISTRY_CANDIDATES="ghcr.nju.edu.cn ghcr.linkos.org ghcr.milu.moe ghcr.registry.cyou ghcr.chenby.cn docker.1ms.run/ghcr.io proxy.vvvv.ee/ghcr.io ghcr.io"
DOCKER_USERNAME=66maer
VERSION=latest

# ============================================
# 数据库配置
# ============================================
# 🔒 安全提示：请使用强密码！
# 生成方法：openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ============================================
# 后端配置
# ============================================
# 🔒 安全提示：JWT 密钥必须足够长且随机！
# 生成方法：openssl rand -base64 48
SECRET_KEY=CHANGE_ME_TO_STRONG_SECRET_KEY_AT_LEAST_32_CHARACTERS

# ============================================
# API 配置
# ============================================
API_BASE_URL=/api/v2

# ============================================
# Bot 配置
# ============================================
# Bot 监听地址和端口（容器内）
BOT_HOST=0.0.0.0
BOT_PORT=8080

# Bot 对外端口（宿主机）
BOT_EXTERNAL_PORT=8080

# ============================================
# 其他配置
# ============================================
ENVIRONMENT=production
